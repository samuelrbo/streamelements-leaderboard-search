# Path to your browser executable (Edge or Chrome)
# Example (Edge):
# BROWSER_EXECUTABLE="C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe"
# Example (Chrome):
# BROWSER_EXECUTABLE="C:\Program Files\Google\Chrome\Application\chrome.exe"
BROWSER_EXECUTABLE=""

# Remote debugging port
BROWSER_DEBUG_PORT=9222

# Browser profile directory (must be outside WSL)
BROWSER_PROFILE_DIR="C:\browser-dev-profile"

# WebSocket URL used by Puppeteer (WSL2 connects to Windows browser)
# Usually: ws://localhost:9222/devtools/browser
BROWSER_WS_URL=""