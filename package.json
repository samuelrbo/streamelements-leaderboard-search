{
  "name": "streamelements-leaderboard-search",
  "version": "1.2.0",
  "description": "Chrome extension that adds leaderboard search and personal points display to StreamElements.",
  "main": "index.js",
  "scripts": {
    "test:e2e:docker": "docker compose -f docker-compose.e2e.yml up --build --abort-on-container-exit",
    "test:e2e": "jest --selectProjects e2e --verbose --colors --no-cache",
    "test:unit": "jest --selectProjects unit",
    "build": "node scripts/build-extension.js",
    "bump": "node scripts/version-bump.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samuelrbo/streamelements-leaderboard-search.git"
  },
  "keywords": [
    "chrome-extension",
    "streamelements",
    "leaderboard",
    "twitch",
    "puppeteer",
    "jest"
  ],
  "author": "Samuel Oliveira",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/samuelrbo/streamelements-leaderboard-search/issues"
  },
  "homepage": "https://github.com/samuelrbo/streamelements-leaderboard-search#readme",
  "devDependencies": {
    "archiver": "^7.0.1",
    "dotenv": "^17.3.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "puppeteer": "^24.40.0",
    "puppeteer-core": "^24.40.0"
  }
}
