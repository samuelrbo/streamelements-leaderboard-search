{
  "name": "__MSG_extName__",
  "description": "__MSG_extDescription__",
  "version": "1.1.2",
  "manifest_version": 3,
  "default_locale": "en",
  "homepage_url": "https://github.com/samuelrbo/streamelements-leaderboard-search",
  "content_scripts": [
    {
      "matches": [
        "https://streamelements.com/*"
      ],
      "js": [
        "scripts/constants.js",
        "scripts/utils.js",
        "scripts/content.js"
      ]
    }
  ],
  "host_permissions": [
    "https://streamelements.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png"
  }
}
