{
  "name": "__MSG_extName__",
  "description": "__MSG_extDescription__",
  "version": "1.2.0",
  "manifest_version": 3,
  "options_ui": {
    "page": "pages/options/index.html",
    "open_in_tab": true
  },
  "side_panel": {
    "default_path": "pages/options/index.html"
  },
  "action": {
    "default_title": "__MSG_extName__",
    "default_popup": "pages/options/index.html"
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "default_locale": "en",
  "homepage_url": "https://github.com/samuelrbo/streamelements-leaderboard-search",
  "content_scripts": [
    {
      "matches": ["https://streamelements.com/*"],
      "js": ["scripts/constants.js", "scripts/utils.js", "scripts/content.js"]
    }
  ],
  "host_permissions": ["<all_urls>"],
  "permissions": ["storage", "sidePanel", "contextMenus"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png"
  }
}
